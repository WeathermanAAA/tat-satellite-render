# .env.s1.example -- copy to `.env` and fill in YOUR values. PLACEHOLDERS ONLY.
# NEVER commit a real .env (it is gitignored).
#
#   cp .env.s1.example .env
#   # edit .env: set the AWS_* (SQS) + R2_* (shadow) values
#   docker compose -p tat-s1 -f docker-compose.s1.yml up -d --build
#
# The S1 ingest worker (s1_ingest.py) needs TWO credential sets:
#   * AWS  -- to long-poll the SQS queue NOAA's SNS topic feeds (IAM user
#             tat-sat-ingest: Receive/Delete/GetQueueAttributes on our queues).
#   * R2   -- to write shadow frames + latest_times.json (Object Read & Write on
#             the bucket; S1 writes ONLY under the shadow/ prefix).

# ---------------------------------------------------------------------------
# Kill switch. true (default) -> the worker consumes + renders + writes shadow/.
# false -> the worker IDLES, writes NOTHING; still serves a (disabled) /health.
# ---------------------------------------------------------------------------
S1_ENABLED=true

# ---------------------------------------------------------------------------
# AWS (SQS) -- the tat-sat-ingest IAM credentials. Region MUST be us-east-1
# (NOAA's NewGOES19Object topic + our queue live there).
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=YOUR_TAT_SAT_INGEST_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_TAT_SAT_INGEST_SECRET_ACCESS_KEY
AWS_DEFAULT_REGION=us-east-1

# The queue the IaC (infra/s1_sqs_sns.sh) created + subscribed. Copy these from
# the IaC summary output (they are NOT secrets, but are env so the worker finds
# them). DLQ url is optional -- only used to surface DLQ depth in /health.
S1_QUEUE_URL=https://queue.amazonaws.com/532918216657/tat-sat-goes19-cmip
S1_DLQ_URL=https://queue.amazonaws.com/532918216657/tat-sat-goes19-cmip-dlq

# ---------------------------------------------------------------------------
# Cloudflare R2 (S3-compatible) -- where shadow frames + latest_times.json go.
# Use the SAME bucket + token as the meso/floater workers (Object Read & Write).
# S1 writes ONLY under shadow/sat/goes19/meso2/ir/ -- it never touches prod keys.
# (§5.7 recommends a token scoped to sat/* + shadow/* only; the existing
# bucket-scoped meso token also works for the shadow-only S1.)
# ---------------------------------------------------------------------------
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET=triple-a-tropics-media

# R2 prefix. Leave as `shadow` -- S1 is SHADOW ONLY (no prod cutover in Stage 1).
S1_R2_PREFIX=shadow

# ---------------------------------------------------------------------------
# Optional tunables (sane defaults baked into s1_ingest.py).
# ---------------------------------------------------------------------------
# S1_BACKFILL_INTERVAL_S=60     # ListObjectsV2 reconcile cadence (fallback authority)
# S1_BACKFILL_LOOKBACK_MIN=120  # recent NOAA prefix window the backfill scans
# S1_RETAIN_H=72                # shadow rolling-window retention (multi-day audit)
# S1_RENDER_TIMEOUT_S=60        # per-/render HTTP timeout (< queue VisibilityTimeout 120)
# S1_WATCHDOG_S=600             # liveness self-exit if a cycle stalls this long
# S1_STALE_AFTER_S=600          # /health flips a source stale past this
# LOG_LEVEL=INFO
