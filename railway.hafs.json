{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfigPath": "nixpacks-hafs.toml"
  },
  "deploy": {
    "startCommand": ". /opt/venv/bin/activate && python hafs_render_poller.py",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
