# .env.meso.example -- copy to `.env` and fill in YOUR values. PLACEHOLDERS ONLY.
# NEVER commit a real .env. The .env file is gitignored.
#
#   cp .env.meso.example .env
#   # edit .env: set the four R2_* values + keep MESO_ENABLED=true
#   docker compose -f docker-compose.meso.yml up -d --build

# ---------------------------------------------------------------------------
# Kill switch. true (default) -> the poller discovers + renders + writes meso/.
# false -> the poller IDLES, writes NOTHING (no frames, no manifests); it still
# serves a (disabled) /health so a watcher sees it is intentionally off.
# ---------------------------------------------------------------------------
MESO_ENABLED=true

# ---------------------------------------------------------------------------
# Cloudflare R2 (S3-compatible) -- where meso/ frames + manifests are written.
# Use the SAME bucket as the floater/render workers; the meso poller writes only
# under the `meso/` prefix, so it never touches floater or other keys.
# Create an R2 API token (Object Read & Write) in the Cloudflare dashboard.
# ---------------------------------------------------------------------------
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET=triple-a-tropics-media

# R2 key prefix. Leave as `meso` unless you are running an isolated staging copy.
R2_PREFIX=meso

# ---------------------------------------------------------------------------
# Render wiring. With docker-compose.meso.yml these are set in the compose file
# (RENDER_BASE_URL=http://meso-render:8080, RATE_MIN_SPACING_S=1.0); override
# here only if you point the poller at a DIFFERENT/public render service -- then
# set RATE_MIN_SPACING_S=7 so the cold-band cadence stretches under the public
# 10 req/min limiter.
# RENDER_BASE_URL=http://meso-render:8080
# RATE_MIN_SPACING_S=1.0

# ---------------------------------------------------------------------------
# Optional tunables (sane defaults baked into meso_poller.py).
# ---------------------------------------------------------------------------
# CADENCE_TARGET_S=60          # GOES hot-band (ir/irbd) target seconds
# COLD_CADENCE_TARGET_S=300    # GOES cold-band (wv/swir/true-color) floor seconds
# COLD_CADENCE_TARGET_HIMA_S=150  # Himawari cold-band floor -- tracks the Target
#                              # sub-scan cadence so ALL 6 Himawari bands hit 150s
#                              # (set 300 to revert Himawari cold to the old stretch)
# MESO_HIMAWARI_PRODUCT=target # "target" = 2.5-min AHI Target sub-scans (all bands);
#                              # "fldk" reverts the WHOLE Himawari sector to 10-min
# MESO_TC_FLDK=false           # read by the RENDER service: true keeps JUST
#                              # true-color on 10-min FLDK (revert if the B03 0.5km
#                              # Target fetch is too heavy); other bands stay Target
# SECTORS_REFRESH_S=120        # how often each sector's extent is re-discovered
# EXTENT_STALE_AFTER_S=1800    # health flips a sector "stale" past this since last scan
# RECENT_WINDOW_H=6            # native-cadence retention window
# HISTORY_WINDOW_H=24          # thinned-history retention window
# THIN_SPACING_S=300           # thinning spacing (5 min) in the history zone
# FAIL_THRESHOLD=3             # consecutive discovery failures -> "failing"
# HEALTH_PORT=8090             # poller /health port (compose curls it)
# LOG_LEVEL=INFO
#
# Self-heal watchdog (never-stale). A daemon thread force-exits the poller when
# EVERY sector has gone stale (a silent WEDGE) so `restart: always` recovers it
# clean -- the 503 healthcheck alone only DETECTS a freeze, it cannot act on it.
# Defaults clear the worst healthy staleness with >3x margin (never trips on a
# single late scan); a single stale source while another is fresh never fires.
# MESO_SELFHEAL=true           # kill switch -- set false to disable the watchdog
# SELFHEAL_STALE_GOES_S=600    # GOES sector stale threshold (~10x the 60s scan)
# SELFHEAL_STALE_HIMA_S=900    # Himawari stale threshold (~6x the 150s Target)
# SELFHEAL_GRACE_S=300         # boot grace before the watchdog can fire
# SELFHEAL_CHECK_S=30          # watchdog poll cadence
