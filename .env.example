# Origins allowed to call /render from a browser (CORS). Comma-separated.
ALLOWED_ORIGINS=https://triple-a-tropics.com,https://www.triple-a-tropics.com,http://localhost:8000

# Max simultaneous renders (RAM-spike safety on small Railway plans).
MAX_CONCURRENT_RENDERS=2

# Per-IP rate limit on /render (cache hits exempt). slowapi syntax.
RATE_LIMIT=10/minute

# How long "latest" renders stay cached (seconds). 5 min = 300.
LATEST_CACHE_TTL=300

# Bucket selection is time-based by default (see goes.pick_buckets_for_time):
#   - 'latest' / t >= 2025-04-04: noaa-goes19
#   - 2018-08-01 <= t < 2025-04-04: noaa-goes19 -> noaa-goes16 (fallback)
#   - t < 2018-08-01:              noaa-goes16
# Set GOES_BUCKET to a single bucket name to override the picker (forces
# every render to that bucket, regardless of requested time).
# GOES_BUCKET=noaa-goes16

# ---------------------------------------------------------------------------
# HAFS render worker (hafs_render_poller.py - the 4th service, Railway Pro,
# startCommand `python hafs_render_poller.py`, no port/healthcheck). Writes
# rendered PNGs + manifest to R2 DIRECTLY (floater pattern), gated to a SHADOW
# prefix in Stage 2 so the Actions cron stays the sole LIVE writer.
# ---------------------------------------------------------------------------
# R2 credentials (same bucket as the floater/intensity workers). R2_*_KEY_ID
# falls back to AWS_*; R2_ENDPOINT is required.
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET=triple-a-tropics-media

# SHADOW in Stage 2 (the cron owns the live models/hafs keys). Flip to
# `models/hafs` at the Stage 3 cutover (and gate the cron's render off).
HAFS_R2_PREFIX=shadow/models/hafs

# Render parallelism. Railway Pro = 8 vCPU for this service -> 8 workers (2x the
# 4-core Actions runner). Set EXPLICITLY (do not trust os.cpu_count() in a
# container - it reports the host's cores, not the plan limit).
HAFS_JOBS=8
# Ingest pool width (GRIB decode = memory-bound; 8-wide OOM'd the heavy
# parent.atm/hafsb frames on this host, 4 fits). Catch-up renders use the SAME
# width, so an incremental render can't OOM where the full one fits.
HAFS_INGEST_JOBS=4

# INTRA-CYCLE CATCH-UP. While the rendered cycle is still the newest, re-check
# upstream each poll for (model, storm, domain) pairs that were absent or still
# uploading at render time (late HAFS-B, late storms) and render the ones that
# have since completed, publishing them ADDITIVELY (no prune, no re-render of
# completed pairs). false -> pure cycle-id gating (the pre-catch-up behavior).
# HAFS_CATCHUP=true
# A pair whose catch-up render keeps failing is abandoned after this many
# attempts (visible in render_summary.json skipped_pairs).
# HAFS_CATCHUP_MAX_ATTEMPTS=3

# Hard wall-clock watchdog on one cycle's render (kills the render tree if it
# wedges). Mirrors the cron's timeout-minutes: 120.
RENDER_TIMEOUT_S=7200
# Poll cadence (cheap S3 listing between renders). STALE_AFTER_S must exceed the
# watchdog so the health watcher never false-alarms mid-render (defaults to
# RENDER_TIMEOUT_S + 30 min).
POLL_INTERVAL_S=120
# STALE_AFTER_S=9000

# Render scope - leave at defaults to match update-hafs.yml exactly (all models,
# both domains, all products). HERBIE_DATA is the field-cache dir.
# HAFS_MODELS=hafsa,hafsb
# HAFS_DOMAINS=storm.atm,parent.atm
# HAFS_PRODUCTS=        # empty -> generator default (all 11)
HERBIE_DATA=/tmp/herbie_data
